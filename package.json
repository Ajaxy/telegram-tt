    "lowlight": "^3.3.0",
    "music-metadata": "^11.12.3",
    "opus-recorder": "github:Ajaxy/opus-recorder#116830a",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "qr-code-styling": "^1.9.2"
  },
  "browserslist": [
    "baseline widely available"
  ]
}
